    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@duckdb/duckdb-wasm": "^1.33.1-dev45.0",
    "@lezer/highlight": "^1.2.3",
    "@types/node": "^20.11.19",
    "@vitest/ui": "^3.2.4",
    "codemirror": "^6.0.2",
    "jsdom": "^26.1.0",
    "sass": "^1.89.2",
