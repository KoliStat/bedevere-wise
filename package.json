    "vega-embed": "^7.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js"
    },
    "./ui": {
      "types": "./dist/ui.d.ts",
      "import": "./dist/ui.es.js"
    },
    "./duckdb": {
      "types": "./dist/duckdb.d.ts",
      "import": "./dist/duckdb.es.js"
    },
    "./style.css": "./dist/style.css"
