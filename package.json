  "description": "Open SAS, SPSS, Stata, Parquet, and Excel files in your browser. Query them with SQL — no install, no upload.",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "homepage": "https://github.com/caerbannogwhite/bedevere-wise",
  "keywords": [
    "sas",
    "sas7bdat",
    "sas-transport",
    "xpt",
    "spss",
    "sav",
    "stata",
    "dta",
