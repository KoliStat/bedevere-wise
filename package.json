    "data-viewer",
    "data-exploration",
    "biostatistics",
    "clinical-data",
    "cdisc",
    "local-first",
    "browser-based"
  ],
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && node scripts/verify-build.mjs",
    "build:lib": "rm -rf dist && vite build --config vite.config.lib.ts && tsc -p tsconfig.lib.json",
    "prepublishOnly": "bun run build:lib",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
