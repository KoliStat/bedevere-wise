node_modules/
.pnp/
.pnp.js

# Production
dist/
build/

# Misc
.DS_Store
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor directories and files
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Per-machine DuckDB WASM extension builds, except `stats-duck` —
# that snapshot is committed so production deploys (CI or manual) ship
# the same parser-extension bytes regardless of the build machine.
public/extensions/*
!public/extensions/stats-duck/

# Claude Code local settings
.claude/

# sigillo MCP local index
.sigillo/

# Temp
src/data.ts
# Local-only test data; embed harness fixtures are excepted so the
# /embed route has something to demo against on a fresh clone.
testfiles/*
!testfiles/embed-demo.csv
!testfiles/embed-demo.parquet
!testfiles/embed-harness.html